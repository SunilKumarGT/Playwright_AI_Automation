import { of, interval } from 'rxjs';
import { map, filter, distinct, take, mergeMap, debounceTime, switchMap, concatMap } from 'rxjs/operators';

// Simulating an observable emitting values
const source$ = of('1', '2', '3', '3', '4', '5', 'a', '6', '7', '3');

OIEULKSDFHKHDFZHSADJHSADHH
source$.pipe(
  // Filter out non-numeric values
  filter(value => !isNaN(Number(value))),
  
  // Map values to numbers
  map(value => Number(value)),
  
  // Remove duplicates
  distinct(),
  
  // Take only the first 5 emissions
  take(5),

  // Merge with another observable that emits a sequence after 1 second delay
  mergeMap(val => interval(1000).pipe(
    map(innerValue => `Outer Value: ${val}, Inner Value: ${innerValue}`)
  )),

  // Switch to a new observable each time
  switchMap(val => of(`${val} switched!`)),

  // Debounce emissions by 500ms (useful for user input handling)
  debounceTime(500)
)
.subscribe({
  next: val => console.log('Emitted Value:', val),
  complete: () => console.log('Complete!')
});

